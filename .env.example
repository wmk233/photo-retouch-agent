# --- Server settings (v0.3.0) ---
PHOTO_AGENT_API_KEY=
PHOTO_AGENT_RATE_LIMIT=10
PHOTO_AGENT_MAX_CONCURRENT=3
PHOTO_AGENT_DATABASE_PATH=data/photo_retouch.db
PHOTO_AGENT_LOG_LEVEL=INFO

# Agent action: mock | qwen | wan | seedream
PHOTO_AGENT_IMAGE_PROVIDER=mock

# Agent brain: local | deepseek | glm | qwen | doubao
PHOTO_AGENT_BRAIN_PROVIDER=local

# Alibaba Cloud Model Studio / DashScope
DASHSCOPE_API_KEY=
DASHSCOPE_WORKSPACE_ID=
DASHSCOPE_REGION=beijing
DASHSCOPE_IMAGE_MODEL=qwen-image-2.0-pro
DASHSCOPE_WAN_MODEL=wan2.7-image-pro
DASHSCOPE_VISION_MODEL=qwen3-vl-plus

# Optional full endpoint override. Keep this server-side to avoid client-side SSRF.
# DASHSCOPE_ENDPOINT=https://YOUR_WORKSPACE_ID.cn-beijing.maas.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
# DASHSCOPE_VISION_ENDPOINT=https://YOUR_WORKSPACE_ID.cn-beijing.maas.aliyuncs.com/compatible-mode/v1/chat/completions

PHOTO_AGENT_PROVIDER_TIMEOUT=180

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_ENDPOINT=https://api.deepseek.com/chat/completions

ZHIPU_API_KEY=
ZHIPU_MODEL=glm-5v-turbo
# ZHIPU_ENDPOINT=https://open.bigmodel.cn/api/paas/v4/chat/completions

# Volcengine Ark: Doubao vision brain and Seedream action
ARK_API_KEY=
ARK_VISION_MODEL=doubao-seed-2-0-lite-260215
ARK_IMAGE_MODEL=doubao-seedream-5-0-260128
# ARK_CHAT_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/chat/completions
# ARK_IMAGE_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/images/generations
